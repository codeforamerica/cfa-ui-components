<% extra_class = html_attrs&.delete(:class) %>
<%= link_to @back_url,
      class: "btn btn--back #{extra_class}".strip,
      disabled: @disabled,
      "aria-disabled": @disabled,
      tabindex: (@disabled ? -1 : nil),
      **(html_attrs || {}) do %>
  <%= inline_icon(:arrow_left, size: 24, aria_hidden: true) %>
  <%= I18n.t("back") %>
<% end %>
