<div class="select-field">
  <% invalid = @form.object.errors[@method].any? %>
  <%= @form.label @method, label_with_optional_marker, id: "#{@method}-label", class: "label block" %>
  <% if @help_text %>
    <p class="help_text"><%= @help_text %></p>
  <% end %>
  <div
    x-data="{
      open: false,
      disabled: <%= @disabled ? "true" : "false" %>,
      value: '<%= current_value %>',
      label: '<%= current_label %>',
      options: <%= options_json %>,
      activeIndex: <%= initial_active_index %>,
      typeahead: '',
      typeaheadTimer: null,
      listboxId: '<%= @method %>-listbox',
      buttonId: '<%= @method %>',

      optionId(i) { return this.buttonId + '-option-' + i },

      openList(focusSelected) {
        if (this.disabled) return
        this.open = true

        if (focusSelected) {
          const selectedIndex = this.options.findIndex(o => String(o.value) === String(this.value))
    this.activeIndex = selectedIndex >= 0 ? selectedIndex : 0
    } else if (this.activeIndex < 0) {
          this.activeIndex = 0
        }

        this.$nextTick(() => this.scrollActive())
      },
      closeList(restoreFocus) {
      this.open = false
      if (restoreFocus) this.$refs.button.focus()
      },
      selectAt(i) {
      if (this.disabled) return
      const option = this.options[i]
      this.value = String(option.value)
      this.label = option.label
      this.activeIndex = i
      this.closeList(true)
      },
      move(delta) {
      if (this.disabled) return
      if (!this.open) {
      this.openList(true)
      return
      }
      const n = this.options.length
      const start = this.activeIndex < 0 ? (delta > 0 ? -1 : 0) : this.activeIndex
        this.activeIndex = (start + delta + n) % n
        this.scrollActive()
        },
        moveTo(i) {
        if (this.disabled) return
        if (!this.open) this.openList(false)
        this.activeIndex = i
        this.scrollActive()
        },
        scrollActive() {
        const el = document.getElementById(this.optionId(this.activeIndex))
        if (el) el.scrollIntoView({ block: 'nearest' })
        },
        handleType(e) {
        if (this.disabled) return
        if (e.altKey || e.ctrlKey || e.metaKey) return
        if (!e.key || e.key.length !== 1) return
        if (e.key === ' ' || e.key === 'Enter' || e.key === 'Tab' || e.key === 'Escape') return
        e.preventDefault()
        clearTimeout(this.typeaheadTimer)
        this.typeahead += e.key.toLowerCase()
        this.typeaheadTimer = setTimeout(() => { this.typeahead = '' }, 500)
        const n = this.options.length
        const startFrom = this.typeahead.length > 1 ? this.activeIndex : this.activeIndex + 1
        for (let i = 0; i < n; i++) {
          const idx = ((startFrom < 0 ? 0 : startFrom) + i) % n

          if (this.options[idx].label.toLowerCase().startsWith(this.typeahead)) {
            if (!this.open) this.openList(false)
            this.activeIndex = idx
            this.scrollActive()
            return
          }
        }
      }
    }"
    class="cfa-custom-select select-field__wrapper"
    @click.outside="closeList(false)"
  >
          <button
      type="button"
      x-ref="button"
      id="<%= @method %>"
      class="cfa-custom-select__button"
      :class="{
        'cfa-custom-select__button--open': open,
        'cfa-custom-select__button--disabled': disabled
      }"
      role="combobox"
      aria-haspopup="listbox"
      :aria-controls="listboxId"
      aria-invalid="<%= invalid %>"
      :aria-expanded="open.toString()"
      aria-disabled="<%= @disabled %>"
      <%= "tabindex=-1" if @disabled %>
      :aria-activedescendant="open && activeIndex >= 0 ? optionId(activeIndex) : null"
            @click="open ? closeList(false) : openList(true)"
            @keydown.arrow-down.prevent="move(1)"
            @keydown.arrow-up.prevent="move(-1)"
            @keydown.home.prevent="open && moveTo(0)"
            @keydown.end.prevent="open && moveTo(options.length - 1)"
            @keydown.enter.prevent="open ? selectAt(activeIndex) : openList(true)"
            @keydown.space.prevent="open ? selectAt(activeIndex) : openList(true)"
            @keydown.escape.prevent="open && closeList(true)"
            @keydown.tab="open && (open = false)"
            @keydown="handleType($event)"
            >
            <span x-text="label" class="cfa-custom-select__value"></span>
            <span
        class="cfa-custom-select__chevron-wrap"
        :class="open ? 'cfa-custom-select__chevron-wrap--open' : ''"
      >
              <span
          class="cfa-custom-select__chevron"
          :class="open ? 'cfa-custom-select__chevron--open' : ''"
        ></span>
            </span>
          </button>
          <ul
      :id="listboxId"
      x-show="open"
      x-cloak
      class="cfa-custom-select__listbox"
      role="listbox"
      :aria-labelledby="'<%= @method %>-label'"
    >
            <% options.each_with_index do |option, idx| %>
              <li
          role="option"
          :id="optionId(<%= idx %>)"
          class="cfa-custom-select__option"
          :class="{ 'cfa-custom-select__option--active': activeIndex === <%= idx %> }"
          :aria-selected="value === '<%= option[:value] %>' ? 'true' : 'false'"
          @click="selectAt(<%= idx %>)"
          @mouseenter="activeIndex = <%= idx %>"
        >
                <%= option[:label] %>
              </li>
            <% end %>
          </ul>
          <%= @form.hidden_field @method, "x-model": "value", disabled: @disabled %>
        </div>
        <%= render(FormErrorsComponent.new(form: @form, method: @method)) %>
      </div>
