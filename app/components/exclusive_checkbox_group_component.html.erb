<fieldset <% if @aria_labelledby %>aria-labelledby="<%= @aria_labelledby %>"<% end %> x-data="{
  uncheckMatching(selector) {
    this.$root.querySelectorAll(selector).forEach((cb) => {
      if (cb.checked) {
        cb.checked = false;
        cb.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });
  },
  onOptionChange(event) {
    if (event.target.matches('input[type=checkbox]') && event.target.checked) {
      this.uncheckMatching('[data-exclusive-checkbox-group=exclusive] input[type=checkbox]');
    }
  },
  onExclusiveChange(event) {
    if (event.target.matches('input[type=checkbox]') && event.target.checked) {
      this.uncheckMatching('[data-exclusive-checkbox-group=options] input[type=checkbox]');
    }
  },
  handleItemClick(event) {
    if (event.target.closest('input, label, button, a, [role=button], [data-no-toggle]')) return;
    const item = Array.from(event.currentTarget.children).find((child) => child.contains(event.target));
    if (!item) return;
    const checkbox = item.querySelector('input[type=checkbox]');
    if (!checkbox || checkbox.disabled) return;
    checkbox.click();
  }
}" class="fieldset-group cfa-stack-xl">
  <% if @legend %>
    <legend class="sr-only"><%= @legend %></legend>
  <% end %>
  <div data-exclusive-checkbox-group="options" class="cfa-stack-xl [&>*]:cursor-pointer" @change="onOptionChange($event)" @click="handleItemClick($event)">
    <%= content %>
  </div>

  <% if exclusive_option? %>
    <div data-exclusive-checkbox-group="exclusive" class="[&>*]:cursor-pointer" @change="onExclusiveChange($event)" @click="handleItemClick($event)">
      <%= exclusive_option %>
    </div>
  <% end %>
</fieldset>
