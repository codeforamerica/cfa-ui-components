<div class="<%= class_names("cfa-step-indicator cfa-stack-med", @css_class) %>">
  <div class="flex gap-x-[7px]"
       role="progressbar"
       aria-label="<%= I18n.t("cfaui.step_indicator.label") %>"
       aria-valuemin="0"
       aria-valuemax="<%= total_steps %>"
       aria-valuenow="<%= current_step %>"
       aria-valuetext="<%= title %>">
    <% total_steps.times do |index| %>
      <span class="flex-1 min-w-px h-2 rounded-lg <%= filled?(index) ? "bg-border-success" : "bg-border-secondary" %>"></span>
    <% end %>
  </div>

  <div class="cfa-stack-sm">
    <p class="font-bold text-text-default leading-none" aria-hidden="true"><%= title %></p>
    <% if content? %>
      <div class="text-text-default"><%= content %></div>
    <% end %>
  </div>
</div>
