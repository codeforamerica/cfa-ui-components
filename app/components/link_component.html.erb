<%= link_to @url, target: "_blank", rel: "noopener noreferrer", **html_attrs do %>
  <span><%= @label %></span>
  <% if external? %>
    <span class="sr-only"><%= @external_sr_label %></span>
    <%= inline_icon("launch", size: 20, label: nil, css_class: "link__icon") %>
  <% else %>
    <span class="sr-only"><%= @sr_label %></span>
  <% end %>
<% end %>
