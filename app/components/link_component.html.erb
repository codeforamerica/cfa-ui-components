<%# Inline elements are kept whitespace-free so the only gap between label and icon is the icon's margin (matches Figma's 4px). %>
<%= link_to @url, target: "_blank", rel: "noopener noreferrer", **html_attrs do %>
  <span><%= @label %></span><% if external? %><span class="sr-only"><%= @external_sr_label %></span><%= inline_icon("launch", size: 24, label: nil, css_class: "ml-cfa-xsm") %><% else %><span class="sr-only"><%= @sr_label %></span><% end %><% end %>
