<div class="space-y-2">
  <%= @form.label @method, @label, class: "label block #{required_class}" %>
  <% if @help_text %>
    <p class="help_text">
      <%= @help_text %>
    </p>
  <% end %>
  <div class="relative max-w-sm">
    <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-black-700 font-bold">
      $
    </span>
    <%= @form.number_field @method,
      min: @min_num,
      max: @max_num,
      step: @step_num,
      required: @required,
      inputmode: "decimal",
      class: "no-spinner w-full rounded-sm border border-zinc-900 pl-7 pr-3 py-2" %>
  </div>
  <%= render(FormErrorsComponent.new(form: @form, method: @method)) %>
</div>
