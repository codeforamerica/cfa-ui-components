<% help_id = "#{@form.field_id(@method)}_help" if @help_text %>
<div class="space-y-cfa-sm" x-data x-init="Alpine.store('<%= @method %>', '<%= current_value %>');">
  <%= @form.label @method, @label, class: "label block #{required_class}" %>
  <% if @help_text %>
    <p id="<%= help_id %>" class="help_text">
      <%= @help_text %>
    </p>
  <% end %>
  <%= @form.collection_select @method, @collection, @item_value_method, @item_label_method, {prompt: "- Select -"}, {"x-model" => "$store.#{@method}", "aria-describedby" => help_id} %>
  <%= render(FormErrorsComponent.new(form: @form, method: @method)) %>
</div>
