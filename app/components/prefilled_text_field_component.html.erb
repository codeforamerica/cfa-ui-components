<% if @heading %>
  <% label_id = "#{@label.parameterize}-#{object_id}" %>
  <div class="cfa-stack-sm">
      <%= content_tag(@heading, @label, class: "label block", id: label_id) %>
      <%= content_tag(@text ? :span : :div, @text || content, class: "w-full max-w-sm #{@style}", aria: {labelledby: label_id}) %>
  </div>
<% else %>
  <dl class="cfa-stack-sm">
      <dt class="label block"><%= @label %></dt>
      <dd class="w-full max-w-sm ml-0 <%= @style %>"><%= @text || content %></dd>
  </dl>
<% end %>
