<div class="contents"
     x-data="{condition: false, announcement: '', ready: false, announceTimer: null}"
     x-effect="condition = $store.<%= store_key %> === '<%= @value %>' ||
                           (Array.isArray($store.<%= store_key %>) && $store.<%= store_key %>.includes('<%= @value %>'))"
     x-init="$nextTick(() => ready = true);
             $watch('condition', visible => {
               if (!ready) return;
               const message = '<%= content_description %> is now ' + (visible ? 'visible' : 'hidden');
               clearTimeout(announceTimer);
               announcement = '';
               announceTimer = setTimeout(() => {
                 announcement = message;
                 announceTimer = setTimeout(() => announcement = '', 5000);
               }, 50);
             })">
  <p class="sr-only" aria-live="assertive" aria-atomic="true" role="alert" x-text="announcement"></p>
  <div x-cloak x-show="condition" class="cfa-stack-med">
    <%= content %>
  </div>
</div>
