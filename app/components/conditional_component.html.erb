<div class="contents"
     x-data="{condition: false}"
     x-effect="condition = $store.<%= store_key %> === '<%= @value %>' ||
                           (Array.isArray($store.<%= store_key %>) && $store.<%= store_key %>.includes('<%= @value %>'))">
  <p class="sr-only" aria-live="polite" role="status"
     x-text="'<%= content_description %> is now ' + (condition ? 'visible' : 'hidden')">
  </p>
  <%# No x-cloak: the content stays visible until Alpine hides it, so if Alpine %>
  <%# never boots the conditional fields remain reachable rather than stuck hidden. %>
  <div x-show="condition" class="cfa-stack-med">
    <%= content %>
  </div>
</div>
