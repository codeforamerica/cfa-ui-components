<div>
  <% invalid = @form.object.errors[@method].any? %>
  <p class="text-[16px] mb-cfa-sm">
    <strong><%= @label %></strong>
  </p>
  <% if @helper_text %>
    <p class="help_text mb-cfa-sm">
      <%= @helper_text %>
    </p>
  <% end %>
  <div class="flex">
    <!-- MONTH -->
    <div>
      <%= label_tag input_id(2), @label_month, class: "label" %><br>
      <div
        x-data="{ open: false, value: '<%= month_value %>', label: '<%= month_value.present? ? month_options.to_h.invert[month_value] : @label_month_select %>' }"
        class="relative mr-cfa-sm mt-cfa-sm w-[210px]"
        @click.outside="open = false"
        @keydown.escape.window="open = false"
      >
        <!-- Trigger -->
        <button
          type="button"
          id="<%= input_id(2) %>"
          class="
            flex h-[48px] w-full items-center justify-between overflow-hidden
            rounded border border-[#c8ced2] bg-white
            pl-[12px] text-[20px] leading-none text-text-default
            focus-visible:outline-4 focus-visible:outline-[#2f9c95]
          "
          :class="open ? 'rounded-b-none border-b-0' : ''"
          aria-haspopup="listbox"
          :aria-expanded="open.toString()"
          @click="open = !open"
        >
          <span x-text="label"></span>
          <!-- Right chevron block -->
          <span class="chevron-wrap">
            <span class="chevron" :class="open ? 'chevron--open' : ''"></span>
          </span>
        </button>
        <!-- Dropdown -->
        <ul
          x-show="open"
          x-cloak
          class="
            absolute left-0 top-[48px] z-10 w-full
            !m-0 !list-none !p-0 !pl-0 !space-y-0
            border-x border-b border-[#c8ced2] bg-white
          "
          role="listbox"
        >
          <% month_options.each do |label, value| %>
            <li
              role="option"
              class="
                flex h-[51px] w-full items-center
                border-t border-[#c8ced2]
                px-[16px] text-[20px] leading-none text-text-default
                first:border-t-0
                hover:bg-background-disabled
              "
              @click="
                value = '<%= value %>';
                label = '<%= label %>';
                open = false;
              "
            >
              <%= label %>
            </li>
          <% end %>
        </ul>
        <%= hidden_field_tag param_name(2), month_value, "x-model": "value" %>
      </div>
    </div>
    <!-- DAY -->
    <div>
      <%= label_tag input_id(3), @label_day, class: "label" %><br>
      <%= @form.text_field "#{@method}(3i)",
            value: day_value,
            id: input_id(3),
            type: "text",
            inputmode: "numeric",
            minlength: 1,
            maxlength: 2,
            placeholder: "DD",
            aria: { invalid: invalid },
            class: "mr-cfa-sm mt-cfa-sm h-[48px] w-[56px]" %>
    </div>
    <!-- YEAR -->
    <div>
      <%= label_tag input_id(1), @label_year, class: "label" %><br>
      <%= @form.text_field "#{@method}(1i)",
            value: year_value,
            id: input_id(1),
            type: "text",
            inputmode: "numeric",
            minlength: 4,
            maxlength: 4,
            placeholder: "YYYY",
            aria: { invalid: invalid },
            class: "mr-cfa-sm mt-cfa-sm h-[48px] w-[86px]" %>
    </div>
  </div>
  <%= render(FormErrorsComponent.new(form: @form, method: @method)) %>
</div>